{
  "name": "cashflow",
  "private": true,
  "workspaces": [
    "backend",
    "frontend"
  ],
  "scripts": {
    "setup": "npm install && npm run db:migrate",
    "dev": "concurrently -n api,web -c blue,green \"npm run dev -w cashflow-backend\" \"npm run dev -w frontend\"",
    "db:migrate": "npm run db:migrate -w cashflow-backend",
    "build": "npm run build -w frontend",
    "test": "npm run test -w cashflow-backend"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  },
  "dependencies": {
    "multer": "^2.1.1"
  }
}
